  create view "statistic_db"."analytics"."stg_stock_movements__dbt_tmp"
    
    
  as (
    -- 

-- with source_data as (
--     select * from "statistic_db"."postgres_raw"."stock_movements"
-- )

-- select
--     md5(cast(transaction_date as varchar) || ticker || transaction_type || cast(quantity as varchar)) as stock_movement_id,
    
--     lower(investor) as investor,
--     lower(transaction_type) as transaction_type,
--     cast(transaction_date as date) as traded_at,
--     upper(ticker) as ticker,
--     lower(organization) as company_name,
--     cnpj,
--     quantity,
--     unit_price,
--     total_amount,
--     "Taxa de liquidação" as settlement_fee,
--     "Emolumentos" as emoluments,
--     "IRFR s/ operações" as income_tax_withheld,
--     "month" as report_month,
--     "To invest" as target_invest_amount,
--     "Difference" as price_difference,
    
--     arquivo_origem
-- from source_data



with source_data as (
    select * from "statistic_db"."postgres_raw"."stock_movements"
)

select
    md5(cast(transaction_date as varchar) || ticker || transaction_type || cast(quantity as varchar)) as stock_movement_id,
    
    lower(investor) as investor,
    lower(transaction_type) as transaction_type,
    cast(transaction_date as date) as traded_at,
    upper(ticker) as ticker,
    lower(organization) as company_name,
    cnpj,
    
    -- Se for venda, a quantidade fica negativa para deduzir do estoque de ações
    case 
        when lower(transaction_type) = 'venda' then -1 * quantity
        else quantity
    end as quantity,
    
    unit_price,
    
    -- Se for venda, o montante total fica negativo para deduzir do saldo financeiro
    case 
        when lower(transaction_type) = 'venda' then -1 * total_amount
        else total_amount
    end as total_amount,
    
    "Taxa de liquidação" as settlement_fee,
    "Emolumentos" as emoluments,
    "IRFR s/ operações" as income_tax_withheld,
    "month" as report_month,
    "To invest" as target_invest_amount,
    "Difference" as price_difference,
    
    arquivo_origem
from source_data
  );
