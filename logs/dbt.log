[0m20:54:02.789960 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with dados_consolidados as (
    -- 1. Calcula as cotas e o valor financeiro direto da RAW para todos os investidores válidos
    select
        initcap(lower(investor)) as investor,
        ticker,
        coalesce(sum(
            case 
                when transaction_type = 'Compra' then quantity
                when transaction_type = 'Venda' then -quantity
                else 0 
            end
        ), 0) as quantidade_cotas,
        coalesce(sum(
            case 
                when transaction_type = 'Compra' then total_amount
                when transaction_type = 'Venda' then -total_amount
                else 0 
            end
        ), 0) as valor_investido_financeiro
    from postgres_raw.stock_movements
    where lower(investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and ticker is not null
    group by 1, 2
),

precos_mercado as (
    -- 2. Busca os preços atualizados pelo Python
    select 
        ticker,
        current_price
    from postgres_raw.current_prices
),

portfolio_base as (
    -- 3. Aplica as regras de exceção de Renda Fixa (CDB) e calcula o valor por ativo
    select
        d.investor,
        d.ticker,
        case 
            when d.ticker = 'CDB' then 1
            else d.quantidade_cotas 
        end as quantidade_cotas,
        case 
            when d.ticker = 'CDB' then round(d.valor_investido_financeiro::numeric, 2)
            else coalesce(p.current_price, 0.00) 
        end as preco_atual_mercado,
        case 
            when d.ticker = 'CDB' then round(d.valor_investido_financeiro::numeric, 2)
            else round((d.quantidade_cotas * coalesce(p.current_price, 0.00))::numeric, 2)
        end as patrimonio_atual_ativo
    from dados_consolidados d
    left join precos_mercado p on d.ticker = p.ticker
    where 
        (d.ticker = 'CDB' and d.valor_investido_financeiro > 0) 
        or (d.ticker != 'CDB' and d.quantidade_cotas > 0)
)

-- 4. Adiciona as funções de janela para somatórios totais e percentuais
select
    investor,
    ticker,
    quantidade_cotas,
    preco_atual_mercado,
    patrimonio_atual_ativo,
    
    -- Soma o patrimônio total apenas daquela pessoa específica
    sum(patrimonio_atual_ativo) over(partition by investor) as patrimonio_total_investidor,
    
    -- Soma o patrimônio de absolutamente todo mundo junto (Portfólio Global)
    sum(patrimonio_atual_ativo) over() as patrimonio_total_global,
    
    -- Calcula a relevância (%) desse ativo dentro da carteira do investidor
    round(
        (patrimonio_atual_ativo / nullif(sum(patrimonio_atual_ativo) over(partition by investor), 0) * 100)::numeric, 
        2
    ) as percentual_na_carteira
from portfolio_base
order by investor, patrimonio_atual_ativo desc
  );
  
