    case 
        when lower("Descrição") ilike '%inclusao de pagamento%' then true
        when lower("Descrição") ilike '%pagamento efetuado%' then true
        when lower("Descrição") ilike '%pagamento recebido%' then true
        else false
    end as is_payment_transaction
from source_data
  );
