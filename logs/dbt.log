  create  table "statistic_db"."analytics"."fct_monthly_investments__dbt_tmp"
  
  
    as
  
  (
    

with recursive indexed_transactions as (
    -- 1. Ordena cronologicamente APENAS os tickers oficiais de investimento
    select
        row_number() over (partition by ticker order by traded_at asc) as transaction_index,
        traded_at::date as traded_date,
        ticker,
        -- Força a quantidade a ser negativa se o tipo for venda (garantia extra)
        case 
            when lower(transaction_type) = 'venda' and quantity > 0 then quantity * -1
            else quantity
        end as quantity,
        unit_price
    from "statistic_db"."analytics"."stg_investments"
    -- LISTA BRANCA: Só entra no gráfico o que for investimento real ou reserva
    where ticker in ('CDB_Reserva_102.2', 'CDB_Pós_104.3', 'SNAG11') 
),

trade_history_recursive as (
    -- 2. CTE Recursiva para calcular o Preço Médio Real de mercado (Contabilidade Pura)
    select
        transaction_index,
        traded_date,
        ticker,
        quantity as qtd_acumulada,
        unit_price as preco_medio,
        (quantity * unit_price) as custo_aplicado
    from indexed_transactions
    where transaction_index = 1

    union all

    select
        t.transaction_index,
        t.traded_date,
        t.ticker,
        (r.qtd_acumulada + t.quantity) as qtd_acumulada,
        case
            when (r.qtd_acumulada + t.quantity) <= 0 then 0
            -- Se for COMPRA, atualiza o preço médio
            when t.quantity > 0 then 
                ((r.qtd_acumulada * r.preco_medio) + (t.quantity * t.unit_price)) / (r.qtd_acumulada + t.quantity)
            -- Se for VENDA, mantém o preço médio anterior
            else r.preco_medio
        end as preco_medio,
        case
            when (r.qtd_acumulada + t.quantity) <= 0 then 0
            else (r.qtd_acumulada + t.quantity) * case
                when t.quantity > 0 then 
                    ((r.qtd_acumulada * r.preco_medio) + (t.quantity * t.unit_price)) / (r.qtd_acumulada + t.quantity)
                else r.preco_medio
            end
        end as custo_aplicado
    from indexed_transactions t
    join trade_history_recursive r on t.ticker = r.ticker and t.transaction_index = r.transaction_index + 1
),

monthly_snapshots as (
    -- 3. Pega o último saldo válido de cada ativo dentro de cada mês trabalhado
    select distinct on (date_trunc('month', traded_date)::date, ticker)
        date_trunc('month', traded_date)::date as data_mes,
        ticker,
        qtd_acumulada,
        custo_aplicado
    from trade_history_recursive
    order by date_trunc('month', traded_date)::date, ticker, traded_date desc, transaction_index desc
),

-- 4. Cria uma matriz de tempo para não deixar buracos nos meses sem movimentação
all_months as (
    select distinct date_trunc('month', traded_at)::date as data_mes from "statistic_db"."analytics"."stg_investments"
),
all_tickers as (
    select distinct ticker from "statistic_db"."analytics"."stg_investments" where ticker in ('CDB_Reserva_102.2', 'CDB_Pós_104.3', 'SNAG11')
),
timeline_matrix as (
    select m.data_mes, t.ticker from all_months m cross join all_tickers t
),

filled_portfolio as (
    -- 5. Propaga o saldo dos meses anteriores para o mês atual
    select
        matrix.data_mes,
        matrix.ticker,
        coalesce(snap.qtd_acumulada, 
            lag(snap.qtd_acumulada) over (partition by matrix.ticker order by matrix.data_mes)
        ) as qtd_no_mes,
        coalesce(snap.custo_aplicado, 
            lag(snap.custo_aplicado) over (partition by matrix.ticker order by matrix.data_mes)
        ) as custo_no_mes
    from timeline_matrix matrix
    left join monthly_snapshots snap on matrix.data_mes = snap.data_mes and matrix.ticker = snap.ticker
),

latest_market_prices as (
    select ticker, current_price from "statistic_db"."analytics"."stg_current_prices"
),

metrics_per_month as (
    -- 6. Aplica a precificação atual sobre os saldos corrigidos
    select
        f.data_mes,
        f.ticker,
        coalesce(f.custo_no_mes, 0) as valor_aplicado,
        case 
            when coalesce(f.qtd_no_mes, 0) <= 0 then 0
            when p.current_price is not null then (f.qtd_no_mes * p.current_price)
            else coalesce(f.custo_no_mes, 0)
        end as valor_mercado
    from filled_portfolio f
    left join latest_market_prices p on f.ticker = p.ticker
    where f.qtd_no_mes > 0 or f.custo_no_mes > 0
)

-- 7. Consolidação final limpa para o gráfico do Metabase
select
    data_mes,
    sum(valor_aplicado) as total_aplicado,
    sum(valor_mercado) as total_atual,
    sum(valor_mercado) - sum(valor_aplicado) as ganho_de_capital
from metrics_per_month
group by 1
order by data_mes asc
  );
  
