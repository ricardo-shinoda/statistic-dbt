  create  table "statistic_db"."analytics"."fct_unified_balance__dbt_tmp"
  
  
    as
  
  (
    

with dados_investimentos as (
    -- 1. Calcula o saldo nominal de investimentos (Compra - Venda) por pessoa
    select
        investor, -- Garanta que essa coluna existe com ESSE nome no seu stg_stock_movements!
        coalesce(sum(
            case 
                when transaction_type = 'Compra' then total_amount
                when transaction_type = 'Venda' then -total_amount
                else 0 
            end
        ), 0) as saldo_investido_puro,
        min(case when ticker = 'CDB' and organization = 'Banco C6' then transaction_date end) as data_marco_cdb_c6
    from "statistic_db"."analytics"."stg_stock_movements"
    group by 1 -- Agrupa pela primeira coluna mapeada (investor) para evitar confusão de escopo
),

total_gastos_casa_pos_balanco as (
    -- 2. Regra de Negócio: Soma absolutamente todos os pagamentos da aba como 'Casa'
    -- filtrando apenas os que aconteceram a partir do marco zero do CDB C6
    select
        coalesce(sum(p.valor), 0) as total_gasto_casa
    from "statistic_db"."analytics"."stg_card_payments" p
    cross join (
        select data_marco_cdb_c6 
        from dados_investimentos 
        where investor = 'Casa'
    ) marco
    where p.data_compra >= marco.data_marco_cdb_c6
),

dados_entradas as (
    -- 3. Soma as receitas por recebedor
    select
        receiver as investor,
        coalesce(sum(value), 0) as total_recebido
    from "statistic_db"."analytics"."stg_income"
    group by receiver
)

-- 4. Consolidação e Cálculo do Saldo Real Atual
select
    coalesce(inv.investor, ent.investor) as investor,
    
    -- Métricas de Referência Visual
    round(coalesce(ent.total_recebido, 0)::numeric, 2) as mais_total_entradas,
    round(coalesce(inv.saldo_investido_puro, 0)::numeric, 2) as saldo_investido_nominal,
    
    case 
        when coalesce(inv.investor, ent.investor) = 'Casa' 
            then round((select total_gasto_casa from total_gastos_casa_pos_balanco)::numeric, 2)
        else 0.00
    end as menos_total_gastos,
    
    -- Cálculo Final com a sua Regra de Negócio
    case 
        -- Para a 'Casa', o saldo do CDB C6 absorve e abate todos os pagamentos da aba
        when coalesce(inv.investor, ent.investor) = 'Casa' then
            round((coalesce(inv.saldo_investido_puro, 0) - (select total_gasto_casa from total_gastos_casa_pos_balanco))::numeric, 2)
        -- Para os outros (Ricardo, Luísa, Lucas, Paula), o saldo atual é o que entrou de Receita + Investimentos
        else
            round((coalesce(ent.total_recebido, 0) + coalesce(inv.saldo_investido_puro, 0))::numeric, 2)
    end as saldo_atual_calculado

from dados_investimentos inv
full outer join dados_entradas ent on inv.investor = ent.investor
order by saldo_atual_calculado desc
  );
  
