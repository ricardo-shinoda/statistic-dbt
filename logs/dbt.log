          or lower(m.transaction_type) like '%juros sobre capital%'
          or lower(m.transaction_type) like '%provento%'
      )
)

select
    investor,
    ticker,
    tipo_provento,
    traded_at,
    mes_competencia,
    round(valor_recebido::numeric, 2) as valor_recebido
from provents_history
order by traded_at desc, investor
  );
  
