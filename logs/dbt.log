[0m07:56:45.628620 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with fluxo_posicoes as (
    -- 1. Consolida a posição real e limpa de cada investidor e ticker
    select
        initcap(lower(m.investor)) as investor,
        m.ticker,
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.quantity
                when m.transaction_type = 'Venda' then -m.quantity
                else 0 
            end
        ), 0) as quantidade_cotas_atual,
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.total_amount
                when m.transaction_type = 'Venda' then -m.total_amount
                else 0 
            end
        ), 0) as saldo_financeiro_cdb
    from postgres_raw.stock_movements m
    where lower(m.investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações')
    group by 1, 2
),

precos_mercado as (
    -- 2. Busca os preços de mercado atuais
    select 
        ticker,
        current_price
    from postgres_raw.current_prices
),

valores_calculados as (
    -- 3. Junta as pontas e calcula o patrimônio real isolado de cada ativo
    select
        f.investor,
        f.ticker,
        case 
            when f.ticker = 'CDB' then round(f.saldo_financeiro_cdb::numeric, 2)
            else round((f.quantidade_cotas_atual * coalesce(p.current_price, 0.00))::numeric, 2)
        end as patrimonio_atual
    from fluxo_posicoes f
    left join precos_mercado p on f.ticker = p.ticker
)

-- 4. Pivota os tickers para colunas e agrupa para deixar exatamente uma linha por investidor
select
    investor,
    
    -- Colunas para cada ativo (Se a pessoa não tiver, fica 0.00)
    coalesce(sum(case when ticker = 'CDB' then patrimonio_atual end), 0.00) as cdb_total,
    coalesce(sum(case when ticker = 'PETR4' then patrimonio_atual end), 0.00) as petr4_total,
    coalesce(sum(case when ticker = 'SNAG11' then patrimonio_atual end), 0.00) as snag11_total,
    coalesce(sum(case when ticker = 'BBSE3' then patrimonio_atual end), 0.00) as bbse3_total,
    coalesce(sum(case when ticker = 'ITSA4' then patrimonio_atual end), 0.00) as itsa4_total,
    coalesce(sum(case when ticker = 'ETH' then patrimonio_atual end), 0.00) as eth_total,
    
    -- Coluna de somatório total do investidor (Soma horizontal da linha)
    round(sum(patrimonio_atual)::numeric, 2) as patrimonio_total_investidor
from valores_calculados
group by investor
order by patrimonio_total_investidor desc
  );
  
