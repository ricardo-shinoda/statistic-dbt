[0m21:10:23.047274 [debug] [Thread-1 (]: Using postgres connection "model.statistic_dbt.fct_investments_portfolio"
[0m21:10:23.047957 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with calculo_por_investor as (
    -- 1. Calcula o patrimônio atual e a soma de cotas de ações/FIIs por investidor
    select
        initcap(lower(m.investor)) as investor,
        
        -- Coluna de Patrimônio Financeiro Atualizado
        sum(
            case 
                -- Exceção para o CDB: Saldo líquido financeiro (Compras - Vendas)
                when m.ticker = 'CDB' and m.transaction_type = 'Compra' then m.total_amount
                when m.ticker = 'CDB' and m.transaction_type = 'Venda' then -m.total_amount
                
                -- Para Ações e FIIs: Quantidade líquida atual * preço atual de mercado
                when m.ticker != 'CDB' and m.transaction_type = 'Compra' then m.quantity * coalesce(p.current_price, 0.00)
                when m.ticker != 'CDB' and m.transaction_type = 'Venda' then -m.quantity * coalesce(p.current_price, 0.00)
                else 0 
            end
        ) as total_investido,

        -- Nova Coluna: Soma apenas a quantidade de cotas de Ações e FIIs (Ignora o CDB)
        sum(
            case 
                when m.ticker != 'CDB' and m.transaction_type = 'Compra' then m.quantity
                when m.ticker != 'CDB' and m.transaction_type = 'Venda' then -m.quantity
                else 0
            end
        ) as total_quantidade_acoes
    from postgres_raw.stock_movements m
    left join postgres_raw.current_prices p on m.ticker = p.ticker
    where lower(m.investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações')
    group by 1
),

dados_finais as (
    -- 2. Traz as linhas individuais de cada investidor
    select 
        investor,
        round(total_investido::numeric, 2) as total_investido,
        round(total_quantidade_acoes::numeric, 0) as total_quantidade_acoes,
        1 as ordem_exibicao
    from calculo_por_investor

    union all

    -- 3. Injeta a linha automática de TOTAL GERAL somando ambas as colunas
    select 
        'TOTAL GERAL' as investor,
        round(sum(total_investido)::numeric, 2) as total_investido,
        round(sum(total_quantidade_acoes)::numeric, 0) as total_quantidade_acoes,
        2 as ordem_exibicao
    from calculo_por_investor
)

select 
    investor,
    total_investido,
    total_quantidade_acoes
from dados_finais
order by ordem_exibicao asc, total_investido desc
  );
  
