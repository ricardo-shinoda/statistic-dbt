  create  table "statistic_db"."analytics"."fct_unified_payments__dbt_tmp"
  
  
    as
  
  (
    


with consolidated_payments as (
    select * from "statistic_db"."analytics"."payments"
)

select
    payment_id,
    amount_brl,
    purchased_at,
    payment_type,
    description,
    comments,
    
    -- Nova hierarquia rica vinda da sua semente unificada
    coalesce(tipo_gasto, 'Variável') as tipo_gasto,
    coalesce(grupo, 'Outros') as grupo,
    coalesce(category_name, 'Não Classificado') as categoria_name,
    coalesce(subcategoria, 'Não Classificado') as subcategory_name,
    
    is_internal_transfer,
    is_payment_transaction
from "statistic_db"."analytics"."payments"
where not is_internal_transfer -- Filtrando transferências se quiser focar apenas em gastos`
  );
  
