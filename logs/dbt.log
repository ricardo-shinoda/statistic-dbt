  create  table "statistic_db"."analytics"."fct_lucas_investments__dbt_tmp"
  
  
    as
  
  (
    

with cotas_liquidas as (
    -- 1. Calcula a quantidade atual de cotas por ativo para o Lucas
    select
        investor,
        ticker,
        coalesce(sum(
            case 
                when transaction_type = 'Compra' then quantity
                when transaction_type = 'Venda' then -quantity
                else 0 
            end
        ), 0) as quantidade_cotas
    from "statistic_db"."analytics"."stg_stock_movements"
    where investor = 'Lucas'
    group by 1, 2
),

precos_mercado as (
    -- 2. Busca os preços que o seu script Python acabou de atualizar no banco
    -- Nota: Substitua pelo seu model/source de preços se você já tiver mapeado no dbt,
    -- caso contrário, usamos o link direto para a tabela que o Python populou.
    select 
        ticker,
        current_price
    from postgres_raw.current_prices
)

-- 3. Junta as cotas com os preços e calcula o valor patrimonial atual
select
    c.investor,
    c.ticker,
    c.quantidade_cotas,
    coalesce(p.current_price, 0.00) as preco_atual_mercado,
    round((c.quantidade_cotas * coalesce(p.current_price, 0.00))::numeric, 2) as patrimonio_atual_total
from cotas_liquidas c
left join precos_mercado p on c.ticker = p.ticker
where c.quantidade_cotas > 0 -- Mostra apenas o que ele tem em carteira hoje
order by patrimonio_atual_total desc
  );
  
