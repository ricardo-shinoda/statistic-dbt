[0m20:34:35.437404 [debug] [Thread-1 (]: On model.statistic_dbt.stg_card_payments: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.stg_card_payments"} */

  create view "statistic_db"."analytics"."stg_card_payments__dbt_tmp"
    
    
  as (
    with source as (
    select * from "statistic_db"."postgres_raw"."payment_card"
),

cleaned as (
    select
        -- Chave primária gerada via hash MD5 dos campos transacionais
        md5(concat(
            coalesce("Data"::text, ''), 
            coalesce("Descrição", ''), 
            coalesce("Valor", 0)::text
        )) as payment_id,
        
        -- Padronização de datas e valores numéricos
        "Data"::date as purchased_at,
        "Valor"::numeric as amount_brl,
        
        -- Mantém a descrição original intacta para auditoria
        "Descrição" as original_description,
        
        -- Limpeza da descrição removendo os prefixos poluídos das adquirentes
        trim(regexp_replace(
            lower("Descrição"), 
            '^(pag\*|mp\*|ifd\*|itau\*|uber\*|pax\*|rec\*|ame\*|compra\s+).\*?\s*', 
            ''
        )) as cleaned_description,
        
        -- Metadados fixos do cartão
        'credit_card' as payment_type,
        false as is_internal_transfer,
        true as is_payment_transaction
    from source
),

mapped as (
    select
        c.*,
        -- Cruzamento com a semente utilizando o termo limpo
        m.tipo_gasto,
        m.grupo,
        m.categoria as category_name,
        m.subcategoria as subcategory_name
    from cleaned c
    left join "statistic_db"."analytics"."category_mapping" m 
        on c.cleaned_description like concat('%', lower(m.search_term), '%')
)

select
    payment_id,
    amount_brl,
    purchased_at,
    payment_type,
    original_description as description,
    null as comments, -- Cartão de crédito não possui campo de comentário livre
    
    -- Tratamento de valores nulos caso o estabelecimento não esteja mapeado no seed
    coalesce(tipo_gasto, 'Variável') as tipo_gasto,
    coalesce(grupo, 'Outros') as grupo,
    coalesce(category_name, 'Não Classificado') as category_name,
    coalesce(subcategory_name, 'Não Classificado') as subcategory_name,
    
    is_internal_transfer,
    is_payment_transaction
from mapped
  );
