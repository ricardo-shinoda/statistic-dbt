[0m21:08:57.886536 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with calculo_por_investor as (
    -- 1. Calcula o patrimônio atual real de cada um (Ações pelo preço atual + CDB pelo fluxo financeiro)
    select
        initcap(lower(m.investor)) as investor,
        sum(
            case 
                -- Exceção para o CDB: Calcula o saldo líquido financeiro (Compras - Vendas)
                when m.ticker = 'CDB' and m.transaction_type = 'Compra' then m.total_amount
                when m.ticker = 'CDB' and m.transaction_type = 'Venda' then -m.total_amount
                
                -- Para Ações e FIIs: Quantidade líquida atual multiplicada pelo preço atual de mercado
                when m.ticker != 'CDB' and m.transaction_type = 'Compra' then m.quantity * coalesce(p.current_price, 0.00)
                when m.ticker != 'CDB' and m.transaction_type = 'Venda' then -m.quantity * coalesce(p.current_price, 0.00)
                else 0 
            end
        ) as total_investido
    from postgres_raw.stock_movements m
    left join postgres_raw.current_prices p on m.ticker = p.ticker
    where lower(m.investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações') -- Remove ruídos
    group by 1
),

dados_finais as (
    -- 2. Traz as linhas individuais de cada pessoa
    select 
        investor,
        round(total_investido::numeric, 2) as total_investido,
        1 as ordem_exibicao -- Garante as pessoas no topo
    from calculo_por_investor

    union all

    -- 3. Injeta a linha automática de Total Geral no fim da tabela
    select 
        'TOTAL GERAL' as investor,
        round(sum(total_investido)::numeric, 2) as total_investido,
        2 as ordem_exibicao -- Garante o Total na última linha
    from calculo_por_investor
)

select 
    investor,
    total_investido
from dados_finais
order by ordem_exibicao asc, total_investido desc
  );
  
