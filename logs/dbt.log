    case 
        when lower(descricao) ilike '%fatura%' then true
        when lower(descricao) ilike '%c6 bank%' then true
        when upper(categoria) = 'PAGAMENTOS' and upper(subcategoria) = 'CARTÃO DE CRÉDITO' then true
        else false
    end as is_internal_transfer

from source_data
  );
