[0m21:07:10.048867 [debug] [Thread-1 (]: Using postgres connection "model.statistic_dbt.fct_investments_portfolio"
[0m21:07:10.049827 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with dados_consolidados as (
    -- 1. Calcula as cotas e o valor financeiro direto da RAW para todos os investidores
    select
        initcap(lower(m.investor)) as investor,
        m.ticker,
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.quantity
                when m.transaction_type = 'Venda' then -m.quantity
                else 0 
            end
        ), 0) as quantidade_cotas,
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.total_amount
                when m.transaction_type = 'Venda' then -m.total_amount
                else 0 
            end
        ), 0) as valor_investido_financeiro
    from postgres_raw.stock_movements m
    where lower(m.investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker is not null
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações')
    group by 1, 2
),

precos_mercado as (
    -- 2. Busca os preços atualizados pelo script Python
    select 
        ticker,
        current_price
    from postgres_raw.current_prices
),

portfolio_base as (
    -- 3. Aplica as regras de exceção de Renda Fixa (CDB) e calcula o valor por ativo
    select
        d.investor,
        d.ticker,
        case 
            when d.ticker = 'CDB' then 0 -- Zeramos a quantidade do CDB para não poluir a soma de ações
            else d.quantidade_cotas 
        end as quantidade_cotas,
        case 
            when d.ticker = 'CDB' then round(d.valor_investido_financeiro::numeric, 2)
            else coalesce(p.current_price, 0.00) 
        end as preco_atual_mercado,
        case 
            when d.ticker = 'CDB' then round(d.valor_investido_financeiro::numeric, 2)
            else round((d.quantidade_cotas * coalesce(p.current_price, 0.00))::numeric, 2)
        end as patrimonio_atual_ativo
    from dados_consolidados d
    left join precos_mercado p on d.ticker = p.ticker
    where 
        (d.ticker = 'CDB' and d.valor_investido_financeiro > 0) 
        or (d.ticker != 'CDB' and d.quantidade_cotas > 0)
)

-- 4. Adiciona as funções de janela para somatórios de ações e patrimônio
select
    investor,
    ticker,
    quantidade_cotas,
    preco_atual_mercado,
    patrimonio_atual_ativo,
    
    -- COLUNAS DE QUANTIDADE DE AÇÕES (Ignora o CDB que foi zerado acima)
    sum(quantidade_cotas) over(partition by investor) as total_cotas_investidor,
    sum(quantidade_cotas) over() as total_cotas_global,
    
    -- COLUNAS DE PATRIMÔNIO FINANCEIRO (Inclui o valor correto do CDB)
    sum(patrimonio_atual_ativo) over(partition by investor) as patrimonio_total_investidor,
    sum(patrimonio_atual_ativo) over() as patrimonio_total_global
from portfolio_base
order by investor, patrimonio_atual_ativo desc
  );
  
