[0m19:38:32.795991 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with fluxo_posicoes as (
    select
        -- Usamos o investor que já veio tratado do staging
        initcap(m.investor) as investor,
        m.ticker,
        
        -- Como o staging já negativou a quantidade na venda, basta somar direto!
        coalesce(sum(m.quantity), 0) as quantidade_cotas_atual,
        
        -- Como o total_amount já é negativo na venda, basta somar direto!
        coalesce(sum(m.total_amount), 0) as saldo_financeiro_cdb
        
    -- 🔄 MUDANÇA CRÍTICA: Lendo do staging limpo e não do banco bruto
    from "statistic_db"."analytics"."stg_stock_movements" m
    where m.investor in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações')
    group by 1, 2
),

precos_mercado as (
    -- Aqui você pode manter o raw temporariamente, ou criar um staging para ele depois
    select 
        ticker,
        current_price
    from "statistic_db"."analytics"."stg_current_prices"
)

select
    f.investor,
    f.ticker,
    
    case 
        when f.ticker = 'CDB' then 1 
        else round(f.quantidade_cotas_atual::numeric, 0)
    end as quantidade_total,
    
    case 
        when f.ticker = 'CDB' then round(f.saldo_financeiro_cdb::numeric, 2)
        else coalesce(p.current_price, 0.00)
    end as preco_atual,
    
    case 
        when f.ticker = 'CDB' then round(f.saldo_financeiro_cdb::numeric, 2)
        else round((f.quantidade_cotas_atual * coalesce(p.current_price, 0.00))::numeric, 2)
    end as montante_total
from fluxo_posicoes f
left join precos_mercado p on f.ticker = p.ticker
where 
    (f.ticker = 'CDB' and f.saldo_financeiro_cdb > 0) 
    or (f.ticker != 'CDB' and f.quantidade_cotas_atual > 0)
order by f.investor, montante_total desc
  );
  
