[0m21:21:06.528548 [debug] [Thread-1 (]: On model.statistic_dbt.fct_investments_portfolio: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "statistic_dbt", "target_name": "dev", "node_id": "model.statistic_dbt.fct_investments_portfolio"} */

  
    

  create  table "statistic_db"."analytics"."fct_investments_portfolio__dbt_tmp"
  
  
    as
  
  (
    

with fluxo_posicoes as (
    -- 1. Calcula a posição líquida atual (compras menos vendas) por investidor e ticker
    select
        initcap(lower(m.investor)) as investor,
        m.ticker,
        
        -- Quantidade líquida atual de cotas (usado para Ações/FIIs)
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.quantity
                when m.transaction_type = 'Venda' then -m.quantity
                else 0 
            end
        ), 0) as quantidade_cotas_atual,
        
        -- Saldo financeiro líquido acumulado (usado exclusivamente para o CDB)
        coalesce(sum(
            case 
                when m.transaction_type = 'Compra' then m.total_amount
                when m.transaction_type = 'Venda' then -m.total_amount
                else 0 
            end
        ), 0) as saldo_financeiro_cdb
    from postgres_raw.stock_movements m
    where lower(m.investor) in ('lucas', 'luísa', 'ricardo', 'casa')
      and m.ticker not in ('Dolar', 'Taxa Liquidação', 'Emolumentos', 'IRRS s/ operações') -- Filtra ruídos
    group by 1, 2
),

precos_mercado as (
    -- 2. Busca os preços atuais vindos do seu script Python
    select 
        ticker,
        current_price
    from postgres_raw.current_prices
)

-- 3. Consolida a linha de cada ativo calculando o patrimônio real atualizado
select
    f.investor,
    f.ticker,
    
    -- Exibição da Quantidade Total por Ticker e Investidor
    case 
        when f.ticker = 'CDB' then 1 -- Para o CDB, consideramos 1 unidade de posição
        else round(f.quantidade_cotas_atual::numeric, 0)
    end as quantidade_total_ticker,
    
    -- Exibição do Preço Atual
    case 
        when f.ticker = 'CDB' then round(f.saldo_financeiro_cdb::numeric, 2) -- O preço do CDB é o próprio saldo
        else coalesce(p.current_price, 0.00)
    end as preco_atual_mercado,
    
    -- Cálculo do Patrimônio Real (Sem inflar o histórico)
    case 
        when f.ticker = 'CDB' then round(f.saldo_financeiro_cdb::numeric, 2)
        else round((f.quantidade_cotas_atual * coalesce(p.current_price, 0.00))::numeric, 2)
    end as patrimonio_atual_ticker
from fluxo_posicoes f
left join precos_mercado p on f.ticker = p.ticker
where 
    (f.ticker = 'CDB' and f.saldo_financeiro_cdb > 0) 
    or (f.ticker != 'CDB' and f.quantidade_cotas_atual > 0)
order by f.investor, patrimonio_atual_ticker desc
  );
  
